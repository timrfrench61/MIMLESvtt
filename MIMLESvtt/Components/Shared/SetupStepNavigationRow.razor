<div class="mt-3 d-flex gap-2 flex-wrap">
    <button class="btn btn-outline-secondary" @onclick="OnBack" disabled="@DisableBack">@BackText</button>
    <button class="btn btn-primary" @onclick="OnContinue" disabled="@DisableContinue">@ContinueText</button>
</div>

@code {
    [Parameter] public string BackText { get; set; } = "Back";
    [Parameter] public string ContinueText { get; set; } = "Continue";
    [Parameter] public bool DisableBack { get; set; }
    [Parameter] public bool DisableContinue { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }
    [Parameter] public EventCallback OnContinue { get; set; }
}
