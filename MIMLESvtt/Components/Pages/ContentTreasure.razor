@page "/content/treasure"
@attribute [Authorize]

<PageTitle>Treasure</PageTitle>

<h1 id="top-treasure">Treasure</h1>

<p class="text-muted">Search, review, and maintain treasure entries from this screen.</p>

<div class="mb-3 d-flex gap-2 flex-wrap">
    <a class="btn btn-outline-secondary" href="/content">Back to Content Home</a>
    <a class="btn btn-outline-secondary" href="/content/import">Open Import</a>
</div>

<h6 class="mb-2">Related Content</h6>
<div class="mb-3 d-flex gap-2 flex-wrap">
    <a class="btn btn-outline-secondary" href="/content/monsters">Open Monsters</a>
    <span class="badge text-bg-primary align-self-center">Current: Treasure</span>
    <a class="btn btn-outline-secondary" href="/content/equipment">Open Equipment</a>
    <a class="btn btn-outline-secondary" href="/content/magic-items">Open Magic Items</a>
</div>
<small class="text-muted d-block mb-3">Use related links to continue cross-type content review after finishing this page.</small>

<div class="mb-3 d-flex gap-2 flex-wrap">
    <button class="btn btn-sm btn-outline-secondary" @onclick="StartCreateMode">Start New Entry</button>
    <a class="btn btn-sm btn-outline-secondary" href="/content/import">Open Import Workflow</a>
    <a class="btn btn-sm btn-outline-secondary" href="/content">Open Content Hub</a>
</div>

<div class="mb-3 d-flex gap-2 flex-wrap">
    <a class="btn btn-sm btn-outline-secondary" href="#top-treasure">Top</a>
    <a class="btn btn-sm btn-outline-secondary" href="#find-treasure">Find</a>
    <a class="btn btn-sm btn-outline-secondary" href="#list-treasure">List</a>
    <a class="btn btn-sm btn-outline-secondary" href="#details-treasure">Details</a>
    <a class="btn btn-sm btn-outline-secondary" href="#edit-treasure">Entry/Edit</a>
</div>
<small class="text-muted d-block mb-3">Recommended sequence: Find -> List -> Details -> Entry/Edit.</small>

<h5 id="find-treasure">Find Treasure</h5>
<p class="text-muted mb-2">Use search and sort to narrow the list before opening details or edit mode.</p>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-6">
                <label class="form-label">Search</label>
                <InputText class="form-control" @bind-Value="searchQuery" placeholder="Search name, id, or type" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Sort</label>
                <InputSelect class="form-select" @bind-Value="sortOption">
                    <option value="@TreasureSort.NameAsc">Name (A-Z)</option>
                    <option value="@TreasureSort.NameDesc">Name (Z-A)</option>
                    <option value="@TreasureSort.TypeAsc">Type (A-Z)</option>
                    <option value="@TreasureSort.TypeDesc">Type (Z-A)</option>
                </InputSelect>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-secondary w-100" @onclick="ClearFilters">Clear</button>
            </div>
        </div>
        <small class="text-muted d-block mt-2">Tip: use filters to narrow to bundle type before opening detail/edit flow.</small>
    </div>
</div>

<h5 id="list-treasure">Treasure List Results</h5>
<div class="mb-2 d-flex gap-3 flex-wrap">
    <small class="text-muted">Visible: <strong>@VisibleTreasure.Count</strong></small>
    <small class="text-muted">Selected: <strong>@(string.IsNullOrWhiteSpace(selectedTreasureId) ? "(none)" : selectedTreasureId)</strong></small>
</div>
<div class="card">
    <div class="card-body">
        @if (VisibleTreasure.Count == 0)
        {
            <div class="alert alert-light border mb-0">No treasure matches current filters. Try clearing filters or broadening your search.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Name</th>
                            <th>Type</th>
                            <th class="text-end">Value</th>
                            <th class="text-end">Qty</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var treasure in VisibleTreasure)
                        {
                            <tr class="@(string.Equals(treasure.Id, selectedTreasureId, StringComparison.Ordinal) ? "table-primary" : string.Empty)">
                                <td><code>@treasure.Id</code></td>
                                <td>@treasure.Name</td>
                                <td>@treasure.TreasureType</td>
                                <td class="text-end">@treasure.Value</td>
                                <td class="text-end">@treasure.Quantity</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => SelectTreasure(treasure.Id)">View</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

<div class="mt-2 d-flex gap-2 flex-wrap">
    <a class="btn btn-sm btn-outline-secondary" href="#edit-treasure">Go to Entry/Edit</a>
    <a class="btn btn-sm btn-outline-secondary" href="#top-treasure">Back to Top</a>
</div>
        }
        <small class="text-muted d-block mt-2">Select any row and choose <strong>View</strong> to populate the detail panel below.</small>
    </div>
</div>

<h5 id="details-treasure" class="mt-4">Treasure Details</h5>
<p class="text-muted mb-2">Review read-only detail values before applying entry/edit changes.</p>
<div class="mb-2 d-flex gap-3 flex-wrap">
    <small class="text-muted">Selected: <strong>@(string.IsNullOrWhiteSpace(selectedTreasureId) ? "(none)" : selectedTreasureId)</strong></small>
    <small class="text-muted">Editor Mode: <strong>@(IsEditMode ? "Edit" : "Create")</strong></small>
</div>

<div class="card mt-3">
    <div class="card-body">
        <h5 class="card-title">Treasure Detail (Read-only)</h5>
        @if (SelectedTreasure is null)
        {
            <div class="alert alert-light border mb-0">Select a treasure entry from the list to view details.</div>
        }
        else
        {
            <dl class="row mb-0">
                <dt class="col-sm-3">Id</dt>
                <dd class="col-sm-9"><code>@SelectedTreasure.Id</code></dd>

                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@SelectedTreasure.Name</dd>

                <dt class="col-sm-3">Type</dt>
                <dd class="col-sm-9">@SelectedTreasure.TreasureType</dd>

                <dt class="col-sm-3">Value</dt>
                <dd class="col-sm-9">@SelectedTreasure.Value</dd>

                <dt class="col-sm-3">Quantity</dt>
                <dd class="col-sm-9">@SelectedTreasure.Quantity</dd>

                <dt class="col-sm-3">Components</dt>
                <dd class="col-sm-9">
                    @if (SelectedTreasure.Components.Count == 0)
                    {
                        <span class="text-muted">(none)</span>
                    }
                    else
                    {
                        <ul class="mb-0">
                            @foreach (var component in SelectedTreasure.Components)
                            {
                                <li>
                                    <code>@component.ComponentId</code> @component.Name (@component.ComponentType) x @component.Quantity worth @component.ValueContribution
                                </li>
                            }
                        </ul>
                    }
                </dd>
            </dl>
        }
    </div>
</div>

<h5 id="edit-treasure" class="mt-4">Treasure Entry/Edit</h5>
<p class="text-muted mb-2">Use this section to create a new treasure entry or edit the currently selected entry.</p>

<div class="card mt-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h5 class="card-title mb-0">Treasure Entry/Edit</h5>
            <span class="badge @(IsEditMode ? "text-bg-primary" : "text-bg-secondary")">@(IsEditMode ? "Edit" : "Create")</span>
        </div>

        <div class="row g-2">
            <div class="col-md-3">
                <label class="form-label">Id (required)</label>
                <InputText class="form-control" @bind-Value="editId" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Name (required)</label>
                <InputText class="form-control" @bind-Value="editName" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Type (required)</label>
                <InputText class="form-control" @bind-Value="editTreasureType" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Value (>= 0)</label>
                <InputNumber class="form-control" @bind-Value="editValue" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Quantity (>= 0)</label>
                <InputNumber class="form-control" @bind-Value="editQuantity" />
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="mb-0">Treasure Components (Optional Bundle Composition)</h6>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="AddComponentRow">Add Component</button>
                </div>
                <small class="text-muted d-block mb-2">Use components to model bundles and mixed-value treasure packs.</small>

                @if (editComponents.Count == 0)
                {
                    <div class="alert alert-light border mb-0">No component rows. Add rows for bundle composition.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Component Id</th>
                                    <th>Name</th>
                                    <th>Type</th>
                                    <th class="text-end">Quantity</th>
                                    <th class="text-end">Value Contribution</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (var i = 0; i < editComponents.Count; i++)
                                {
                                    var component = editComponents[i];
                                    <tr>
                                        <td><InputText class="form-control" @bind-Value="component.ComponentId" /></td>
                                        <td><InputText class="form-control" @bind-Value="component.Name" /></td>
                                        <td><InputText class="form-control" @bind-Value="component.ComponentType" /></td>
                                        <td><InputNumber class="form-control" @bind-Value="component.Quantity" /></td>
                                        <td><InputNumber class="form-control" @bind-Value="component.ValueContribution" /></td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveComponentRow(i)">Remove</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="d-flex gap-2 mt-3">
            <button class="btn btn-outline-secondary" @onclick="ValidateEditorForm">Validate Form</button>
            <button class="btn btn-primary" @onclick="SaveTreasure">Save</button>
            <button class="btn btn-outline-warning" @onclick="CancelEdit">Cancel</button>
            <button class="btn btn-outline-secondary" @onclick="StartCreateMode">New (Create Mode)</button>
        </div>

        <small class="text-muted d-block mt-2">Validate is optional pre-check. Save is the primary action for persisting changes.</small>
        <small class="text-muted d-block">Use <strong>New</strong> to clear editor values and start a fresh entry after save/review.</small>
        <small class="text-muted d-block">Use <strong>Cancel</strong> to leave edit mode without persisting form changes.</small>

        @if (!string.IsNullOrWhiteSpace(editorValidationMessage))
        {
            <div class="alert @(editorValidationPassed ? "alert-success" : "alert-danger") mt-3 mb-0">
                @editorValidationMessage
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(editorSaveMessage))
        {
            <div class="alert @(editorSaveSucceeded ? "alert-success" : "alert-danger") mt-2 mb-0">
                @editorSaveMessage
            </div>
        }

        <div class="mt-3 d-flex gap-2 flex-wrap">
            <a class="btn btn-sm btn-outline-secondary" href="#find-treasure">Back to Find</a>
            <a class="btn btn-sm btn-outline-secondary" href="#list-treasure">Back to List</a>
            <a class="btn btn-sm btn-outline-secondary" href="#details-treasure">Back to Details</a>
            <a class="btn btn-sm btn-outline-secondary" href="#top-treasure">Back to Top</a>
            <a class="btn btn-sm btn-outline-secondary" href="/content/import">Open Import</a>
            <a class="btn btn-sm btn-outline-secondary" href="/content/equipment">Next: Equipment</a>
            <a class="btn btn-sm btn-outline-secondary" href="/content">Open Content Hub</a>
        </div>
    </div>
</div>
