@page "/workspace/checkers-reference"
@attribute [Authorize]

<PageTitle>Checkers Reference</PageTitle>

<h1>Checkers Reference Mode</h1>

<div class="alert alert-info">
    Use this route to bootstrap the workspace into checkers-reference interaction flow.
</div>

<div class="d-flex gap-2">
    <a class="btn btn-primary" href="/workspace?mode=checkers">Open Workspace In Checkers Mode</a>
    <a class="btn btn-outline-secondary" href="/workspace">Open Workspace</a>
</div>
