<div class="mb-3">
    <button class="btn btn-outline-secondary me-2" @onclick="UndoClicked" disabled="@(!CanUndo)">Undo</button>
    <button class="btn btn-outline-secondary" @onclick="RedoClicked" disabled="@(!CanRedo)">Redo</button>
</div>

<div class="mb-3">
    <button class="btn btn-outline-success me-2" @onclick="SaveSessionClicked">Save Game</button>
    <button class="btn btn-outline-info me-2" @onclick="SaveLayoutAsScenarioClicked">Save Current Layout As Scenario</button>
    <button class="btn btn-warning me-2" @onclick="OpenScenarioClicked">Open Scenario For Pending Plan</button>
    <button class="btn btn-danger" @onclick="ActivateScenarioClicked">Activate Pending Scenario</button>
</div>

<div class="mb-3">
    <label class="form-label">Scenario title </label>
    <input class="form-control" value="@ScenarioTitle" @oninput="OnScenarioTitleChanged" />
</div>

@code {
    [Parameter] public bool CanUndo { get; set; }
    [Parameter] public bool CanRedo { get; set; }

    [Parameter] public EventCallback UndoClicked { get; set; }
    [Parameter] public EventCallback RedoClicked { get; set; }
    [Parameter] public EventCallback CreateNewSessionClicked { get; set; }
    [Parameter] public EventCallback OpenSessionClicked { get; set; }
    [Parameter] public EventCallback SaveSessionClicked { get; set; }
    [Parameter] public EventCallback SaveSessionAsClicked { get; set; }
    [Parameter] public EventCallback SaveLayoutAsScenarioClicked { get; set; }
    [Parameter] public EventCallback OpenScenarioClicked { get; set; }
    [Parameter] public EventCallback ActivateScenarioClicked { get; set; }

    [Parameter] public string ScenarioTitle { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ScenarioTitleChanged { get; set; }

    private Task OnScenarioTitleChanged(ChangeEventArgs args) => ScenarioTitleChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);
}
