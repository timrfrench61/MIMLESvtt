@page "/"
@attribute [Authorize]
@using MIMLESvtt.src.Domain.Persistence.Snapshot
@using MIMLESvtt.src.Domain.Persistence.VttSessionNSPC

<PageTitle>Home</PageTitle>

<h1>Game Launcher</h1>

<button class="btn btn-primary mb-3" @onclick="OpenGameSelector">Select Game</button>

@if (isGameSelectorOpen)
{
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h3 class="mb-0">Games</h3>
                <button class="btn btn-sm btn-outline-secondary" @onclick="CloseGameSelector">Close</button>
            </div>

            <div class="mb-4">
                <h5>Open a Game</h5>
                <div class="d-flex gap-2 align-items-center mb-2">
                    <span class="text-muted">View:</span>
                    <button class="btn btn-sm @(campaignBrowserViewMode == CampaignBrowserViewMode.DetailList ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetCampaignBrowserViewMode(CampaignBrowserViewMode.DetailList)">Detail List</button>
                    <button class="btn btn-sm @(campaignBrowserViewMode == CampaignBrowserViewMode.Card ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetCampaignBrowserViewMode(CampaignBrowserViewMode.Card)">Cards</button>
                </div>

                @if (!string.IsNullOrWhiteSpace(savedSessionStatusMessage))
                {
                    <div class="alert alert-info py-2">@savedSessionStatusMessage</div>
                }

                @if (GetCampaignSelections().Count == 0)
                {
                    <div class="text-muted">No games are currently available.</div>
                }
                else if (campaignBrowserViewMode == CampaignBrowserViewMode.DetailList)
                {
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Campaign</th>
                                <th>Current Scenario</th>
                                <th>Current Snapshot</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in GetCampaignSelections())
                            {
                                var selected = string.Equals(selectedCampaignId, entry.CampaignId, StringComparison.OrdinalIgnoreCase);
                                <tr class="@(selected ? "table-primary" : string.Empty)" @onclick="() => SelectCampaign(entry.CampaignId)">
                                    <td><code>@entry.CampaignId</code> - @entry.CampaignName</td>
                                    <td><code>@entry.CurrentScenarioId</code> - @entry.CurrentScenarioName</td>
                                    <td><code>@entry.CurrentSnapshotPath</code></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="d-flex gap-2 align-items-center">
                        <button class="btn btn-primary" @onclick="OpenSelectedCampaign" disabled="@string.IsNullOrWhiteSpace(selectedCampaignId)">Open Campaign</button>
                        <button class="btn btn-outline-danger" @onclick="DeleteSelectedCampaign" disabled="@string.IsNullOrWhiteSpace(selectedCampaignId)">Delete Selected Game</button>
                        <button class="btn btn-outline-secondary" @onclick="RefreshKnownSessions">Refresh</button>
                    </div>
                }
                else
                {
                    <div class="row g-2">
                        @foreach (var entry in GetCampaignSelections())
                        {
                            var selected = string.Equals(selectedCampaignId, entry.CampaignId, StringComparison.OrdinalIgnoreCase);
                            <div class="col-12 col-md-6 col-lg-4">
                                <div class="card h-100 @(selected ? "border-primary" : string.Empty)" style="cursor:pointer" @onclick="() => SelectCampaign(entry.CampaignId)">
                                    <div class="card-body">
                                        <h6 class="card-title mb-1">@entry.CampaignName</h6>
                                        <div><code>@entry.CampaignId</code></div>
                                        <div class="mt-2 text-muted">Current: @entry.CurrentScenarioName</div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="d-flex gap-2 align-items-center mt-2">
                        <button class="btn btn-primary" @onclick="OpenSelectedCampaign" disabled="@string.IsNullOrWhiteSpace(selectedCampaignId)">Open Campaign</button>
                        <button class="btn btn-outline-danger" @onclick="DeleteSelectedCampaign" disabled="@string.IsNullOrWhiteSpace(selectedCampaignId)">Delete Selected Game</button>
                        <button class="btn btn-outline-secondary" @onclick="RefreshKnownSessions">Refresh</button>
                    </div>
                }
            </div>

            <div class="mb-4">
                <h5>Join a Game by Code</h5>
                <div class="d-flex gap-2 align-items-center mb-2">
                    <InputText @bind-Value="joinCode" class="form-control" style="max-width: 260px;" placeholder="Enter join code" />
                    <button class="btn btn-outline-secondary" @onclick="JoinExistingGame">Join</button>
                </div>
                @if (!string.IsNullOrWhiteSpace(joinStatusMessage))
                {
                    <div class="alert alert-warning py-2">@joinStatusMessage</div>
                }
            </div>

            <div>
                <h5>Create a Game</h5>
                <div class="mb-2">
                    <span class="text-muted">Signed in as <strong>@currentUserName</strong> (@(isCurrentUserAdmin ? "Admin" : "Player"))</span>
                </div>
                <div class="d-flex gap-2 align-items-center mb-2">
                    <InputText @bind-Value="newSessionTitle" class="form-control" style="max-width: 240px;" placeholder="Campaign name" />
                    <InputSelect @bind-Value="newCampaignGameboxId" class="form-select" style="max-width: 280px;">
                        <option value="">Select GameBox</option>
                        @foreach (var gameboxId in availableGameboxIds)
                        {
                            <option value="@gameboxId">@gameboxId</option>
                        }
                    </InputSelect>
                </div>
                <div class="mb-2">
                    <small class="text-muted">Pick a GameBox template before creating a game campaign.</small>
                </div>
                <div class="d-flex gap-2 align-items-center">
                    <button class="btn btn-success" @onclick="StartNewSession" disabled="@(!WorkspaceService.State.CanCreateSession)">Create New Campaign</button>
                    @if (!WorkspaceService.State.CanCreateSession)
                    {
                        <span class="text-muted">Admin rights required.</span>
                    }
                </div>
                @if (!string.IsNullOrWhiteSpace(newSessionStatusMessage))
                {
                    <div class="alert alert-info py-2 mt-2">@newSessionStatusMessage</div>
                }

                <h5 class="mt-4">Create New GameBox</h5>
                <div class="d-flex gap-2 align-items-center mb-2">
                    <InputText @bind-Value="newGameboxId" class="form-control" style="max-width: 280px;" placeholder="GameBox id" />
                    <button class="btn btn-outline-secondary" @onclick="CreateNewGamebox" disabled="@(!WorkspaceService.State.CanCreateSession)">Create</button>
                    <button class="btn btn-primary" @onclick="CreateAndEditNewGamebox" disabled="@(!WorkspaceService.State.CanCreateSession)">Create and Edit</button>
                </div>
                @if (!string.IsNullOrWhiteSpace(newGameboxStatusMessage))
                {
                    <div class="alert alert-info py-2 mt-2">@newGameboxStatusMessage</div>
                }
            </div>
        </div>
    </div>
}
