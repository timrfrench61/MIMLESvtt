@page "/workspace/tactical-setup"
@attribute [Authorize]

<PageTitle>Tactical Scenario Setup</PageTitle>

<h1>Tactical Scenario Setup</h1>

<div class="alert alert-info">
    Tactical scenario setup shell is active. Use this page as the dedicated entry point for setup-specific workflows.
</div>

<div class="card mb-3">
    <div class="card-body">
        <h5 class="card-title">Current Scope</h5>
        <ul class="mb-0">
            <li>Dedicated route and page shell for tactical setup.</li>
            <li>Follow-on slices will add setup state, side assignment, and direct scenario-save workflows.</li>
        </ul>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <h5 class="card-title">Setup State (Slice 2)</h5>
        <div class="row g-2">
            <div class="col-md-4">
                <label class="form-label">Surface Id</label>
                <InputText class="form-control" @bind-Value="SetupState.SelectedSurfaceId" />
                @if (AvailableSurfaceIds.Count > 0)
                {
                    <div class="form-text">Known surfaces: @string.Join(", ", AvailableSurfaceIds)</div>
                }
            </div>
            <div class="col-md-4">
                <label class="form-label">Side</label>
                <InputText class="form-control" @bind-Value="SetupState.SideAssignment" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Faction</label>
                <InputText class="form-control" @bind-Value="SetupState.FactionAssignment" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Piece Definition Id</label>
                <InputText class="form-control" @bind-Value="SetupState.PlacementDefinitionId" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Owner Participant Id</label>
                <InputText class="form-control" @bind-Value="SetupState.PlacementOwnerParticipantId" />
                @if (AvailableParticipantIds.Count > 0)
                {
                    <div class="form-text">Known participants: @string.Join(", ", AvailableParticipantIds)</div>
                }
            </div>
            <div class="col-md-2">
                <label class="form-label">X</label>
                <InputNumber class="form-control" @bind-Value="SetupState.PlacementX" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Y</label>
                <InputNumber class="form-control" @bind-Value="SetupState.PlacementY" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Scenario Title</label>
                <InputText class="form-control" @bind-Value="SetupState.ScenarioTitle" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Scenario Path</label>
                <InputText class="form-control" @bind-Value="SetupState.ScenarioPath" />
            </div>
        <div class="mt-3 d-flex gap-2">
            <button class="btn btn-outline-primary" @onclick="ApplySideFactionAssignment">Apply Side/Faction Assignment</button>
            <button class="btn btn-primary" @onclick="SaveSetupAsScenario">Save Setup As Scenario</button>
        </div>
        @if (!string.IsNullOrWhiteSpace(setupStatusMessage))
        {
            <div class="alert alert-info mt-2 mb-0">@setupStatusMessage</div>
        }
        </div>
    </div>
</div>

<div class="d-flex gap-2">
    <button class="btn btn-primary" @onclick="OpenWorkspace">Open Workspace</button>
    <button class="btn btn-outline-secondary" @onclick="GoHome">Back to Home</button>
</div>
