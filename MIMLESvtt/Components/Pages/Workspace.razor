@page "/workspace"
@using MIMLESvtt.src
@inject SessionWorkspaceService WorkspaceService
@inject ITableSessionCommandService CommandService

<PageTitle>Workspace</PageTitle>

<h1>Workspace</h1>

<div class="workspace-canvas-layer">
    @switch (tabletopSurfaceState)
    {
        case TabletopSurfaceState.MissingTabletop:
            <div class="workspace-tabletop-status workspace-tabletop-status-missing">Tabletop unavailable. Select the default x-y grid from Workspace Controls.</div>
            break;
        case TabletopSurfaceState.PageNotLoading:
            <div class="workspace-tabletop-status workspace-tabletop-status-error">Tabletop page is not loading. Verify the workspace state and try again.</div>
            break;
        default:
            <div class="workspace-default-tabletop-grid" aria-label="Default x-y grid tabletop"></div>
            break;
    }
</div>

<button class="btn btn-primary workspace-panel-fab" @onclick="ToggleWorkspacePanel">
    @(isWorkspacePanelOpen ? "Hide Workspace Controls" : "Show Workspace Controls")
</button>

@if (isWorkspacePanelOpen)
{
    <div class="workspace-panel-backdrop" @onclick="CloseWorkspacePanel"></div>
}

<aside class="workspace-slide-panel @(isWorkspacePanelOpen ? "open" : string.Empty)">
    <div class="workspace-slide-panel-header">
        <strong>Workspace Controls</strong>
        <button class="btn btn-sm btn-outline-secondary" @onclick="CloseWorkspacePanel">Close</button>
    </div>
    <div class="workspace-slide-panel-body">

        <div class="mb-3 p-2 border rounded bg-light">
            <div class="d-flex flex-wrap gap-2 align-items-center">
                <strong>Tabletop Surface</strong>
                <InputSelect @bind-Value="tabletopSurfaceState" class="form-select form-select-sm" style="max-width: 260px;">
                    <option value="@TabletopSurfaceState.DefaultXyGrid">Default x-y grid</option>
                    <option value="@TabletopSurfaceState.MissingTabletop">Missing tabletop</option>
                    <option value="@TabletopSurfaceState.PageNotLoading">Page not loading</option>
                </InputSelect>
            </div>
        </div>

<WorkspaceApplicationSettingsPanel
    CanUndo="@WorkspaceService.State.CanUndo"
    CanRedo="@WorkspaceService.State.CanRedo"
    UndoClicked="UndoLastWorkspaceOperation"
    RedoClicked="RedoLastWorkspaceOperation"
    CreateNewSessionClicked="CreateNewSession"
    OpenSessionClicked="OpenSessionFromPath"
    SaveSessionClicked="SaveCurrentSession"
    SaveSessionAsClicked="SaveCurrentSessionAs"
    SaveLayoutAsScenarioClicked="SaveCurrentLayoutAsScenario"
    OpenScenarioClicked="OpenScenarioForPendingPlan"
    ActivateScenarioClicked="ActivatePendingScenario"
    SessionPath="sessionPath"
    SessionPathChanged="OnSessionPathChangedFromPanel"
    ScenarioPath="scenarioPath"
    ScenarioPathChanged="OnScenarioPathChangedFromPanel"
    ScenarioTitle="scenarioTitle"
    ScenarioTitleChanged="OnScenarioTitleChangedFromPanel" />

@if (!string.IsNullOrWhiteSpace(WorkspaceService.State.LastOperationMessage))
{
    <div class="alert @GetLastOperationAlertClass()">@WorkspaceService.State.LastOperationMessage</div>
}

<WorkspaceSessionSettingsPanel
    CurrentTableSession="WorkspaceService.State.CurrentTableSession"
    WorkspaceState="WorkspaceService.State"
    SessionCounter="sessionCounter"
    SessionTitleInput="@sessionTitleInput"
    SessionTitleInputChanged="OnSessionTitleInputChangedFromPanel"
    UpdateSessionTitleClicked="UpdateSessionTitle" />

@if (WorkspaceService.State.CurrentTableSession is not null)
{

    <div class="mb-3 p-2 border rounded bg-light">
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <strong>Workspace Mode</strong>
            <span class="badge @(WorkspaceService.State.Mode == WorkspaceMode.Edit ? "text-bg-secondary" : "text-bg-success")">@WorkspaceService.State.Mode</span>
            <button class="btn btn-sm btn-outline-secondary" @onclick="SwitchToEditMode" disabled="@(WorkspaceService.State.Mode == WorkspaceMode.Edit)">Edit Mode</button>
            <button class="btn btn-sm btn-outline-success" @onclick="SwitchToPlayMode" disabled="@(WorkspaceService.State.Mode == WorkspaceMode.Play)">Play Mode</button>
        </div>
    </div>

    <div class="mb-3 p-2 border rounded bg-light">
        <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
            <strong>Developer Settings</strong>
            <span class="badge text-bg-warning">Pre-alpha</span>
        </div>
        <div class="d-flex flex-wrap gap-3 align-items-center">
            <div class="form-check mb-0">
                <input id="dev-enable-multiplayer" class="form-check-input" type="checkbox" @bind="WorkspaceService.State.Settings.EnableMultiplayer" @bind:after="OnDeveloperSettingsChanged" />
                <label class="form-check-label" for="dev-enable-multiplayer">Enable Multiplayer</label>
            </div>
            <div class="form-check mb-0">
                <input id="dev-enable-rules-validation" class="form-check-input" type="checkbox" @bind="WorkspaceService.State.Settings.EnableRulesValidation" @bind:after="OnDeveloperSettingsChanged" />
                <label class="form-check-label" for="dev-enable-rules-validation">Enable Rules Validation</label>
            </div>
            <div class="form-check mb-0">
                <input id="dev-enable-stamp-mode" class="form-check-input" type="checkbox" @bind="WorkspaceService.State.Settings.EnableStampMode" @bind:after="OnDeveloperSettingsChanged" />
                <label class="form-check-label" for="dev-enable-stamp-mode">Enable Stamp Mode</label>
            </div>
            <div class="form-check mb-0">
                <input id="dev-enable-board-interaction" class="form-check-input" type="checkbox" @bind="WorkspaceService.State.Settings.EnableBoardInteraction" @bind:after="OnDeveloperSettingsChanged" />
                <label class="form-check-label" for="dev-enable-board-interaction">Enable Board Interaction</label>
            </div>
        </div>
    </div>

    <div class="mb-3 p-2 border rounded bg-light">
        <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
            <strong>Turn / Phase</strong>
            <span>Turn: <strong>@WorkspaceService.State.CurrentTableSession.TurnNumber</strong></span>
            <span>Index: <strong>@WorkspaceService.State.CurrentTableSession.CurrentTurnIndex</strong></span>
            <span>Current Player: <strong>@GetCurrentTurnParticipant()</strong></span>
            <span>Phase: <strong>@(string.IsNullOrWhiteSpace(WorkspaceService.State.CurrentTableSession.CurrentPhase) ? "(none)" : WorkspaceService.State.CurrentTableSession.CurrentPhase)</strong></span>
            <button class="btn btn-sm btn-outline-primary" @onclick="PreviousTurn" disabled="@(WorkspaceService.State.CurrentTableSession.TurnOrder.Count == 0)">Previous Turn</button>
            <button class="btn btn-sm btn-outline-primary" @onclick="AdvanceTurn" disabled="@(WorkspaceService.State.CurrentTableSession.TurnOrder.Count == 0)">Next Turn</button>
        </div>
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <InputText @bind-Value="turnOrderInput" class="form-control form-control-sm" style="max-width: 360px;" placeholder="Turn order: p1, p2, p3" />
            <button class="btn btn-sm btn-outline-secondary" @onclick="InitializeTurnOrderFromInput">Initialize Turn Order</button>
            <InputText @bind-Value="phaseInput" class="form-control form-control-sm" style="max-width: 220px;" placeholder="Current phase" />
            <button class="btn btn-sm btn-outline-secondary" @onclick="SetCurrentPhase">Set Phase</button>
        </div>
    </div>

    <div class="mb-3 p-2 border rounded bg-light">
        <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
            <strong>Initiative / Roster</strong>
            <span>Current: <strong>@GetCurrentTurnParticipant()</strong></span>
            <span>Turn: <strong>@WorkspaceService.State.CurrentTableSession.TurnNumber</strong></span>
            <span>Phase: <strong>@(string.IsNullOrWhiteSpace(WorkspaceService.State.CurrentTableSession.CurrentPhase) ? "(none)" : WorkspaceService.State.CurrentTableSession.CurrentPhase)</strong></span>
        </div>

        @if (WorkspaceService.State.CurrentTableSession.TurnOrder.Count == 0)
        {
            <small class="text-muted">No turn order initialized yet.</small>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Participant</th>
                            <th>Owned Pieces</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < WorkspaceService.State.CurrentTableSession.TurnOrder.Count; i++)
                        {
                            var participantId = WorkspaceService.State.CurrentTableSession.TurnOrder[i];
                            var isActive = i == WorkspaceService.State.CurrentTableSession.CurrentTurnIndex;
                            <tr class="@(isActive ? "table-primary" : string.Empty)">
                                <td>@(i + 1)</td>
                                <td>@GetParticipantDisplayById(participantId)</td>
                                <td>@GetOwnedPiecesSummary(participantId)</td>
                                <td>
                                    <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => MoveTurnParticipantUp(participantId)" disabled="@(i == 0)">↑</button>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => MoveTurnParticipantDown(participantId)" disabled="@(i == WorkspaceService.State.CurrentTableSession.TurnOrder.Count - 1)">↓</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="mb-3 p-2 border rounded bg-light">
        <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
            <strong>Participants</strong>
            <InputText @bind-Value="participantIdInput" class="form-control form-control-sm" style="max-width: 160px;" placeholder="Id" />
            <InputText @bind-Value="participantNameInput" class="form-control form-control-sm" style="max-width: 200px;" placeholder="Name" />
            <button class="btn btn-sm btn-outline-primary" @onclick="AddParticipantToSession">Add Participant</button>
            <InputText @bind-Value="removeParticipantIdInput" class="form-control form-control-sm" style="max-width: 180px;" placeholder="Remove Id" />
            <button class="btn btn-sm btn-outline-danger" @onclick="RemoveParticipantFromSession">Remove Participant</button>
            <InputText @bind-Value="renameParticipantIdInput" class="form-control form-control-sm" style="max-width: 160px;" placeholder="Rename Id" />
            <InputText @bind-Value="renameParticipantNameInput" class="form-control form-control-sm" style="max-width: 200px;" placeholder="New Name" />
            <button class="btn btn-sm btn-outline-secondary" @onclick="RenameParticipantInSession">Rename Participant</button>
        </div>

        @if (WorkspaceService.State.CurrentTableSession.Participants.Count == 0)
        {
            <small class="text-muted">No participants in current session.</small>
        }
        else
        {
            <table class="table table-sm mb-0">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Name</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var participant in WorkspaceService.State.CurrentTableSession.Participants)
                    {
                        <tr>
                            <td>@participant.Id</td>
                            <td>@participant.Name</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
}

@if (WorkspaceService.State.CurrentTableSession is not null)
{
    <h3>Setup</h3>

    <h4>Add Surface</h4>
    <div class="row g-2 mb-3">
        <div class="col">
            <InputText @bind-Value="newSurfaceId" class="form-control" placeholder="Surface Id" />
        </div>
        <div class="col">
            <InputText @bind-Value="newSurfaceDefinitionId" class="form-control" placeholder="Definition Id" />
        </div>
        <div class="col">
            <InputSelect @bind-Value="newSurfaceType" class="form-select">
                @foreach (var type in Enum.GetValues<SurfaceType>())
                {
                    <option value="@type">@type</option>
                }
            </InputSelect>
        </div>
        <div class="col">
            <InputSelect @bind-Value="newCoordinateSystem" class="form-select">
                @foreach (var system in Enum.GetValues<CoordinateSystem>())
                {
                    <option value="@system">@system</option>
                }
            </InputSelect>
        </div>
        <div class="col-auto">
            <button class="btn btn-outline-secondary" @onclick="AddSurface">Add Surface</button>
        </div>
    </div>

    <h4>Add Piece</h4>
    <div class="row g-2 mb-3">
        <div class="col">
            <InputText @bind-Value="newPieceId" class="form-control" placeholder="Piece Id" />
        </div>
        <div class="col">
            <InputText @bind-Value="newPieceDefinitionId" class="form-control" placeholder="Definition Id" />
        </div>
        <div class="col">
            <InputText @bind-Value="newPieceSurfaceId" class="form-control" placeholder="Target Surface Id" />
        </div>
        <div class="col">
            <InputNumber @bind-Value="newPieceX" class="form-control" />
        </div>
        <div class="col">
            <InputNumber @bind-Value="newPieceY" class="form-control" />
        </div>
        <div class="col">
            <InputNumber @bind-Value="newPieceRotation" class="form-control" />
        </div>
        <div class="col">
            <InputText @bind-Value="newPieceOwnerParticipantId" class="form-control" placeholder="Owner (optional)" />
        </div>
        <div class="col-auto">
            <button class="btn btn-outline-secondary" @onclick="AddPiece">Add Piece</button>
        </div>
    </div>

    <h3>Surfaces</h3>
    @if (WorkspaceService.State.CurrentTableSession.Surfaces.Count == 0)
    {
        <p>No surfaces in current session.</p>
    }
    else
    {
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Type</th>
                    <th>Coordinate System</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var surface in WorkspaceService.State.CurrentTableSession.Surfaces)
                {
                    <tr>
                        <td>@surface.Id</td>
                        <td>@surface.Type</td>
                        <td>@surface.CoordinateSystem</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="mb-3 p-2 border rounded bg-light">
            <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                <strong>Surface Workflow Strip</strong>
                <span class="text-muted">Fast switch, default preset mapping, and bootstrap actions</span>
            </div>

            <div class="table-responsive mb-2">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Surface</th>
                            <th>Type / Coordinate</th>
                            <th>Active</th>
                            <th>Default Preset</th>
                            <th>Preset Shortcut</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var surface in WorkspaceService.State.CurrentTableSession.Surfaces)
                        {
                            var isActiveSurface = string.Equals(board.ActiveSurfaceId, surface.Id, StringComparison.Ordinal);
                            var defaultPresetName = board.GetDefaultPresetForSurface(surface.Id)?.Name;

                            <tr class="@(isActiveSurface ? "table-primary" : string.Empty)">
                                <td>@surface.Id</td>
                                <td>@surface.Type / @surface.CoordinateSystem</td>
                                <td>@(isActiveSurface ? "Yes" : "No")</td>
                                <td>@(defaultPresetName ?? "(none)")</td>
                                <td>
                                    <select class="form-select form-select-sm"
                                            value="@GetSurfaceStripPresetValue(surface.Id)"
                                            @onchange="args => OnSurfaceStripPresetChanged(surface.Id, args)">
                                        <option value="">(none)</option>
                                        @foreach (var preset in board.StampPresets)
                                        {
                                            <option value="@preset.Name">@preset.Name</option>
                                        }
                                    </select>
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ActivateSurfaceFromStrip(surface.Id)">Activate</button>
                                    <button class="btn btn-sm btn-outline-secondary"
                                            @onclick="() => ApplyActivePresetToSurface(surface.Id)"
                                            disabled="@string.IsNullOrWhiteSpace(board.ActiveStampPresetName)">
                                        Use Active Preset
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex flex-wrap gap-2 align-items-center">
                <strong>Quick Add Surface:</strong>
                <InputText @bind-Value="quickSurfaceId" class="form-control form-control-sm" style="max-width: 160px;" placeholder="Surface Id" />
                <InputText @bind-Value="quickSurfaceDefinitionId" class="form-control form-control-sm" style="max-width: 200px;" placeholder="Definition Id (optional)" />
                <InputSelect @bind-Value="quickSurfaceType" class="form-select form-select-sm" style="max-width: 140px;">
                    @foreach (var type in Enum.GetValues<SurfaceType>())
                    {
                        <option value="@type">@type</option>
                    }
                </InputSelect>
                <InputSelect @bind-Value="quickSurfaceCoordinateSystem" class="form-select form-select-sm" style="max-width: 140px;">
                    @foreach (var system in Enum.GetValues<CoordinateSystem>())
                    {
                        <option value="@system">@system</option>
                    }
                </InputSelect>
                <button class="btn btn-sm btn-outline-primary" @onclick="QuickAddSurfaceFromStrip">Add</button>

                <strong class="ms-2">Duplicate Active Surface:</strong>
                <InputText @bind-Value="duplicateSurfaceId" class="form-control form-control-sm" style="max-width: 180px;" placeholder="New Surface Id" />
                <button class="btn btn-sm btn-outline-secondary" @onclick="DuplicateActiveSurfaceFromStrip">Duplicate</button>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Active surface for board</label>
            <select class="form-select" value="@board.ActiveSurfaceId" @onchange="OnActiveSurfaceChanged">
                @foreach (var surface in WorkspaceService.State.CurrentTableSession.Surfaces)
                {
                    <option value="@surface.Id">@surface.Id (@surface.Type / @surface.CoordinateSystem)</option>
                }
            </select>
        </div>

        <div class="mb-3 p-2 border rounded bg-light">
            <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
                <strong>Board Visibility</strong>
                <div class="form-check mb-0">
                    <input id="show-surfaces-toggle" class="form-check-input" type="checkbox" @bind="boardVisibility.ShowSurfaces" @bind:after="ApplyBoardVisibilityRules" />
                    <label class="form-check-label" for="show-surfaces-toggle">Show Surfaces</label>
                </div>
                <div class="form-check mb-0">
                    <input id="show-pieces-toggle" class="form-check-input" type="checkbox" @bind="boardVisibility.ShowPieces" @bind:after="ApplyBoardVisibilityRules" />
                    <label class="form-check-label" for="show-pieces-toggle">Show Pieces</label>
                </div>
                <div class="form-check mb-0">
                    <input id="show-markers-toggle" class="form-check-input" type="checkbox" @bind="boardVisibility.ShowMarkers" @bind:after="ApplyBoardVisibilityRules" />
                    <label class="form-check-label" for="show-markers-toggle">Show Markers</label>
                </div>
                <div class="form-check mb-0">
                    <input id="active-surface-only-toggle" class="form-check-input" type="checkbox" @bind="boardVisibility.ActiveSurfaceOnly" @bind:after="ApplyBoardVisibilityRules" />
                    <label class="form-check-label" for="active-surface-only-toggle">Active Surface Only</label>
                </div>
            </div>
            <div class="d-flex flex-wrap gap-2 align-items-center">
                <InputText @bind-Value="boardVisibilityDefinitionFilter" @bind-Value:after="OnDefinitionFilterChanged" class="form-control form-control-sm" style="max-width: 220px;" placeholder="Filter DefinitionId" />
                <InputText @bind-Value="boardVisibilityOwnerFilter" @bind-Value:after="OnOwnerFilterChanged" class="form-control form-control-sm" style="max-width: 220px;" placeholder="Filter OwnerParticipantId" />
            </div>
        </div>

        <div class="mb-3 p-2 border rounded bg-light">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
                <strong>Piece Palette</strong>
                <span class="text-muted">Built from stamp presets</span>
            </div>

            @if (board.GetPiecePaletteEntries().Count == 0)
            {
                <small class="text-muted">No palette entries yet. Save a stamp preset to populate this sidebar list.</small>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>DefinitionId</th>
                                <th>Owner</th>
                                <th>Rotation</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var paletteEntry in board.GetPiecePaletteEntries())
                            {
                                var isActivePaletteEntry = string.Equals(paletteEntry.Name, board.ActiveStampPresetName, StringComparison.Ordinal);
                                <tr class="@(isActivePaletteEntry ? "table-primary" : string.Empty)">
                                    <td>@paletteEntry.Name</td>
                                    <td>@paletteEntry.DefinitionId</td>
                                    <td>@(string.IsNullOrWhiteSpace(paletteEntry.OwnerParticipantId) ? "(none)" : paletteEntry.OwnerParticipantId)</td>
                                    <td>@paletteEntry.InitialRotation</td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => ArmPlacementFromPalette(paletteEntry.Name)">Arm Placement</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="board-panel @(isBoardFocused ? "focused" : string.Empty)"
             tabindex="0"
             @onfocusin="OnBoardFocused"
             @onfocusout="OnBoardBlurred"
             @onkeydown="OnBoardKeyDown"
             @onclick="BoardClicked">
            @if (board.ShouldRenderSurfaceVisuals(boardVisibility.ShowSurfaces))
            {
                <div class="board-grid-overlay"></div>
            }
            @foreach (var piece in board.GetRenderedPiecesForBoard(WorkspaceService.State.CurrentTableSession, boardVisibility))
            {
                <div class="@GetPieceCss(piece)"
                     style="@GetPieceStyle(piece)"
                     @onclick:stopPropagation="true"
                     @onclick="args => OnBoardPieceClicked(piece.Id, args)">
                    @(boardVisibility.ShowMarkers && piece.MarkerIds.Count > 0 ? $"{piece.Id} [{piece.MarkerIds.Count}]" : piece.Id)
                </div>
            }
        </div>

        <div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
            <button class="btn btn-sm btn-outline-secondary" @onclick="ClearBoardSelection">Clear Selection</button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="SelectAllOnActiveSurface">Select All On Active Surface</button>
            <span><strong>@board.GetSelectionSummary()</strong></span>
            @if (!string.IsNullOrWhiteSpace(board.SelectedPieceId))
            {
                <span>Primary: <strong>@board.SelectedPieceId</strong></span>
            }
        </div>

        <div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
            <span><strong>Group Move Δ</strong></span>
            <InputNumber @bind-Value="groupMoveDeltaX" class="form-control form-control-sm" style="max-width: 120px;" />
            <InputNumber @bind-Value="groupMoveDeltaY" class="form-control form-control-sm" style="max-width: 120px;" />
            <button class="btn btn-sm btn-outline-primary" @onclick="MoveSelectedGroupByDelta">Move Selected Group</button>
        </div>

        <div class="mb-3 p-2 border rounded bg-light">
            <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
                <strong>Piece Groups (Stack-lite)</strong>
                <InputText @bind-Value="groupLabelInput" class="form-control form-control-sm" style="max-width: 220px;" placeholder="Group label (optional)" />
                <button class="btn btn-sm btn-outline-primary" @onclick="CreateGroupFromSelection">Create From Selection</button>
                <InputNumber @bind-Value="groupMoveDeltaX" class="form-control form-control-sm" style="max-width: 110px;" />
                <InputNumber @bind-Value="groupMoveDeltaY" class="form-control form-control-sm" style="max-width: 110px;" />
                <button class="btn btn-sm btn-outline-secondary" @onclick="MoveSelectedGroupByDeltaControl" disabled="@string.IsNullOrWhiteSpace(selectedGroupId)">Move Group By Δ</button>
            </div>

            @if (board.PieceGroups.Count == 0)
            {
                <small class="text-muted">No groups yet. Select multiple pieces and create a temporary group.</small>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm mb-0 align-middle">
                        <thead>
                            <tr>
                                <th>Label</th>
                                <th>Members</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var group in board.PieceGroups)
                            {
                                var isActiveGroup = string.Equals(selectedGroupId, group.GroupId, StringComparison.Ordinal);
                                <tr class="@(isActiveGroup ? "table-primary" : string.Empty)">
                                    <td>@group.Label</td>
                                    <td>@board.GetGroupMembersSummary(group.GroupId)</td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => SelectGroup(group.GroupId)">Select Group</button>
                                        <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => MoveGroupByDelta(group.GroupId)">Move</button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DisbandGroup(group.GroupId)">Disband</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="row g-2 mb-3">
            <div class="col-auto align-self-end">
                <div class="form-check">
                    <input id="add-at-click-toggle" class="form-check-input" type="checkbox" @bind="addPieceAtBoardClickMode" />
                    <label class="form-check-label" for="add-at-click-toggle">Add Piece At Board Click</label>
                </div>
            </div>
            @if (addPieceAtBoardClickMode)
            {
                <div class="col-auto align-self-end">
                    <div class="form-check">
                        <input id="stamp-mode-toggle" class="form-check-input" type="checkbox" @bind="stampModeEnabled" disabled="@(!WorkspaceService.State.Settings.EnableStampMode)" />
                        <label class="form-check-label" for="stamp-mode-toggle">Stamp Mode (repeat placement)</label>
                    </div>
                </div>
                <div class="col">
                    <InputText @bind-Value="quickCreatePieceId" @bind-Value:after="OnQuickCreatePieceIdEdited" class="form-control" placeholder="Quick Piece Id" />
                </div>
                <div class="col">
                    <InputText @bind-Value="quickCreateDefinitionId" @bind-Value:after="OnQuickCreateDefinitionEdited" class="form-control" placeholder="Quick Definition Id" />
                </div>
                <div class="col">
                    <InputText @bind-Value="quickCreateOwnerParticipantId" class="form-control" placeholder="Owner (optional)" />
                </div>
                <div class="col">
                    <InputNumber @bind-Value="quickCreateRotation" class="form-control" />
                </div>
                <div class="col-12">
                    <small>Next Id Preview (editable): <strong>@quickCreatePieceId</strong></small>
                </div>
            }
            <div class="col-auto">
                <label class="form-label mb-0">Nudge Step</label>
                <select class="form-select" @bind="selectedNudgeStep">
                    <option value="1">1</option>
                    <option value="5">5</option>
                    <option value="10">10</option>
                </select>
            </div>
            <div class="col-auto align-self-end">
                <div class="form-check">
                    <input id="clamp-toggle" class="form-check-input" type="checkbox" @bind="clampToBoard" />
                    <label class="form-check-label" for="clamp-toggle">Clamp Movement To Board</label>
                </div>
            </div>
            <div class="col-auto">
                <button class="btn btn-outline-dark" @onclick="MoveFromBoardPanel">Move Selected To Clicked Position</button>
            </div>
            <div class="col-auto">
                <button class="btn btn-outline-dark" @onclick="CenterSelected">Center Selected</button>
            </div>
            <div class="col-auto">
                <button class="btn btn-outline-dark" @onclick="RotateLeftQuick">Rotate Left</button>
            </div>
            <div class="col-auto">
                <button class="btn btn-outline-dark" @onclick="RotateRightQuick">Rotate Right</button>
            </div>
            <div class="col-auto align-self-center">
                <small>Last board click: (@lastBoardClickX, @lastBoardClickY)</small>
            </div>
        </div>

        @if (addPieceAtBoardClickMode)
        {
            <div class="mb-3 p-2 border rounded bg-light">
                <div class="d-flex flex-wrap gap-2 align-items-center">
                    <span><strong>Stamp Session:</strong></span>
                    <span>Add-at-click: <strong>@(addPieceAtBoardClickMode ? "On" : "Off")</strong></span>
                    <span>Stamp: <strong>@(stampModeEnabled ? "On" : "Off")</strong></span>
                    <span>Surface: <strong>@(board.ActiveSurfaceId ?? "(none)")</strong></span>
                    <span>Next Id: <strong>@(string.IsNullOrWhiteSpace(quickCreatePieceId) ? "(empty)" : quickCreatePieceId)</strong></span>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="NudgeNextIdDown" disabled="@string.IsNullOrWhiteSpace(quickCreatePieceId)">Id -1</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="NudgeNextIdUp" disabled="@string.IsNullOrWhiteSpace(quickCreatePieceId)">Id +1</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ResetNextIdPreviewToBase">Reset Id To Base</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ClearNextIdPreview">Clear Id Preview</button>
                </div>
                <div class="mt-2 d-flex flex-wrap gap-2 align-items-center">
                    <span>Base Id: <strong>@(string.IsNullOrWhiteSpace(quickCreateBasePieceId) ? "(empty)" : quickCreateBasePieceId)</strong></span>
                    <div class="form-check mb-0">
                        <input id="remember-definition-by-surface" class="form-check-input" type="checkbox" @bind="rememberDefinitionPerSurface" />
                        <label class="form-check-label" for="remember-definition-by-surface">Remember DefinitionId Per Surface</label>
                    </div>
                </div>
                <div class="mt-2 d-flex flex-wrap gap-2 align-items-center">
                    <span><strong>Stamp Presets:</strong></span>
                    <InputText @bind-Value="stampPresetNameInput" class="form-control form-control-sm" style="max-width: 220px;" placeholder="Preset name (optional)" />
                    <button class="btn btn-sm btn-outline-primary" @onclick="SaveStampPreset">Save Preset</button>
                    <select class="form-select form-select-sm" style="max-width: 260px;" value="@selectedStampPresetName" @onchange="OnStampPresetSelected">
                        <option value="">(select preset)</option>
                        @foreach (var preset in board.StampPresets)
                        {
                            <option value="@preset.Name">@preset.Name (@preset.DefinitionId)</option>
                        }
                    </select>
                    <button class="btn btn-sm btn-outline-primary" @onclick="UseSelectedStampPreset" disabled="@string.IsNullOrWhiteSpace(selectedStampPresetName)">Use Preset</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ClearPresetSelection">Clear Selection</button>
                    <InputText @bind-Value="stampPresetRenameInput" class="form-control form-control-sm" style="max-width: 200px;" placeholder="Rename selected to" />
                    <button class="btn btn-sm btn-outline-secondary" @onclick="RenameSelectedStampPreset" disabled="@string.IsNullOrWhiteSpace(selectedStampPresetName)">Rename</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="DuplicateSelectedStampPreset" disabled="@string.IsNullOrWhiteSpace(selectedStampPresetName)">Duplicate</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="SetSelectedPresetAsDefaultForSurface" disabled="@string.IsNullOrWhiteSpace(selectedStampPresetName) || string.IsNullOrWhiteSpace(board.ActiveSurfaceId)">Set Default For Surface</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ClearDefaultPresetForSurface" disabled="@string.IsNullOrWhiteSpace(board.ActiveSurfaceId)">Clear Surface Default</button>
                    <button class="btn btn-sm btn-outline-danger" @onclick="DeleteSelectedStampPreset" disabled="@string.IsNullOrWhiteSpace(selectedStampPresetName)">Delete Preset</button>
                </div>
                <div class="mt-2 d-flex flex-wrap gap-2 align-items-center">
                    <span>Active preset: <strong>@(board.ActiveStampPresetName ?? "(none)")</strong></span>
                    <span>Surface default: <strong>@(GetSurfaceDefaultPresetName() ?? "(none)")</strong></span>
                    <span>Active is surface default: <strong>@(IsActivePresetSurfaceDefault() ? "Yes" : "No")</strong></span>
                </div>
            </div>

            <div class="mb-3 p-2 border rounded bg-light">
                <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
                    <strong>Cross-Surface Stamp Queue</strong>
                    <InputText @bind-Value="stampQueueNote" class="form-control form-control-sm" style="max-width: 220px;" placeholder="Optional label" />
                    <button class="btn btn-sm btn-outline-primary" @onclick="AddCurrentSetupToStampQueue">Add Current Setup To Queue</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ApplyNextQueueItem" disabled="@(board.StampQueue.Count == 0)">Next Queue Item</button>
                    <span>Active Queue Index: <strong>@(board.ActiveStampQueueIndex >= 0 ? (board.ActiveStampQueueIndex + 1).ToString() : "(none)")</strong></span>
                </div>

                @if (board.StampQueue.Count == 0)
                {
                    <small class="text-muted">Queue is empty. Add current surface/preset/id context to build a stamping sequence.</small>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm mb-0 align-middle">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Surface</th>
                                    <th>Preset</th>
                                    <th>Next Id</th>
                                    <th>Label</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (var i = 0; i < board.StampQueue.Count; i++)
                                {
                                    var queueItem = board.StampQueue[i];
                                    var rowIsActive = i == board.ActiveStampQueueIndex;

                                    <tr class="@(rowIsActive ? "table-primary" : string.Empty)">
                                        <td>@(i + 1)</td>
                                        <td>@queueItem.SurfaceId</td>
                                        <td>@(queueItem.PresetName ?? "(none)")</td>
                                        <td>
                                            <input class="form-control form-control-sm"
                                                   value="@queueItem.NextPieceId"
                                                   @onchange="args => UpdateQueueItemNextId(i, args)" />
                                        </td>
                                        <td>@(string.IsNullOrWhiteSpace(queueItem.Label) ? "(none)" : queueItem.Label)</td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ApplyQueueItem(i)">Apply</button>
                                            <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => MoveQueueItemUp(i)" disabled="@(i == 0)">↑</button>
                                            <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => MoveQueueItemDown(i)" disabled="@(i == board.StampQueue.Count - 1)">↓</button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveQueueItem(i)">Remove</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <div class="mt-3 d-flex flex-wrap gap-2 align-items-center">
                    <strong>Queue Templates</strong>
                    <InputText @bind-Value="queueTemplateNameInput" class="form-control form-control-sm" style="max-width: 220px;" placeholder="Template name" />
                    <button class="btn btn-sm btn-outline-primary" @onclick="SaveQueueAsTemplate">Save Current Queue As Template</button>
                    <span>Selected Template: <strong>@(selectedQueueTemplateName ?? "(none)")</strong></span>
                </div>

                @if (board.StampQueueTemplates.Count == 0)
                {
                    <small class="text-muted">No templates yet. Save current queue to reuse this workflow in the session.</small>
                }
                else
                {
                    <div class="table-responsive mt-2">
                        <table class="table table-sm mb-0 align-middle">
                            <thead>
                                <tr>
                                    <th>Template</th>
                                    <th>Steps</th>
                                    <th>Rename To</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var template in board.StampQueueTemplates)
                                {
                                    var isActiveTemplate = string.Equals(template.TemplateName, selectedQueueTemplateName, StringComparison.Ordinal);
                                    <tr class="@(isActiveTemplate ? "table-primary" : string.Empty)">
                                        <td>@template.TemplateName</td>
                                        <td>@template.Items.Count</td>
                                        <td>
                                            <input class="form-control form-control-sm"
                                                   value="@GetTemplateRenameValue(template.TemplateName)"
                                                   @onchange="args => SetTemplateRenameValue(template.TemplateName, args)" />
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ApplyQueueTemplate(template.TemplateName)">Apply</button>
                                            <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => RenameQueueTemplate(template.TemplateName)">Rename</button>
                                            <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => DuplicateQueueTemplate(template.TemplateName)">Duplicate</button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteQueueTemplate(template.TemplateName)">Delete</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }

        <div class="mb-3">
            <small>
                Board keyboard: click board or tab into it to focus. Arrow keys nudge selected piece by @selectedNudgeStep.
                Q rotates left and E rotates right by @QuickRotateIncrement°.
                Keyboard active: <strong>@(isBoardFocused ? "Yes" : "No")</strong>.
            </small>
        </div>

        <div class="mb-3 board-hud">
            <strong>Board HUD:</strong>
            @if (TryGetSelectedPiece(out var hudPiece))
            {
                <span> Piece: @hudPiece.Id | Surface: @hudPiece.Location.SurfaceId | X:@hudPiece.Location.Coordinate.X Y:@hudPiece.Location.Coordinate.Y | Rot:@hudPiece.Rotation.Degrees° </span>
            }
            else
            {
                <span> Piece: (none selected) </span>
            }
            <span> | Nudge: @selectedNudgeStep | Clamp: @(clampToBoard ? "On" : "Off")</span>
            <span> | Add-at-click: @(addPieceAtBoardClickMode ? "On" : "Off")</span>
            @if (addPieceAtBoardClickMode)
            {
                <span> | Stamp Mode: @(stampModeEnabled ? "On" : "Off")</span>
                <span> | Next Piece: @quickCreatePieceId / @quickCreateDefinitionId</span>
            }
        </div>

        @if (TryGetSelectedPiece(out var selectedPiece))
        {
            <div class="mb-3">
                <strong>Selected Piece:</strong>
                @selectedPiece.Id on @selectedPiece.Location.SurfaceId at (@selectedPiece.Location.Coordinate.X, @selectedPiece.Location.Coordinate.Y), rotation @selectedPiece.Rotation.Degrees°, owner @GetOwnerDisplayForPiece(selectedPiece)
            </div>

            <div class="mb-3 p-2 border rounded bg-light">
                <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
                    <strong>Selected Piece Data</strong>
                    <span>Label: <strong>@GetPieceLabel(selectedPiece)</strong></span>
                    <span>HP: <strong>@GetPieceStateDisplayValue(selectedPiece, "HP")</strong></span>
                    <span>Notes: <strong>@GetPieceStateDisplayValue(selectedPiece, "Notes")</strong></span>
                    <span>Tags: <strong>@GetPieceStateDisplayValue(selectedPiece, "Tags")</strong></span>
                    <span>Markers: <strong>@GetMarkerSummary(selectedPiece)</strong></span>
                </div>

                <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
                    <InputText @bind-Value="stateKey" class="form-control form-control-sm" style="max-width: 180px;" placeholder="State Key" />
                    <InputText @bind-Value="stateValue" class="form-control form-control-sm" style="max-width: 220px;" placeholder="State Value" />
                    <button class="btn btn-sm btn-outline-primary" @onclick="ChangePieceState">Add/Update State</button>
                    <InputText @bind-Value="removeStateKey" class="form-control form-control-sm" style="max-width: 180px;" placeholder="Key to remove" />
                    <button class="btn btn-sm btn-outline-danger" @onclick="RemovePieceState">Remove Key</button>
                </div>

                <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
                    <span><strong>HP Quick Update:</strong></span>
                    <InputNumber @bind-Value="quickHpValue" class="form-control form-control-sm" style="max-width: 120px;" />
                    <button class="btn btn-sm btn-outline-secondary" @onclick="SetPieceHpState">Set HP</button>
                </div>

                @if (selectedPiece.State.Count == 0)
                {
                    <small class="text-muted">No state keys on selected piece.</small>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>Key</th>
                                    <th>Value</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in selectedPiece.State.OrderBy(kvp => kvp.Key, StringComparer.Ordinal))
                                {
                                    <tr>
                                        <td>@entry.Key</td>
                                        <td>@FormatStateValue(entry.Value)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
                <strong>Assign Owner</strong>
                <select class="form-select form-select-sm" style="max-width: 280px;" @bind="selectedPieceOwnerParticipantId">
                    <option value="">(none)</option>
                    @foreach (var participant in WorkspaceService.State.CurrentTableSession.Participants)
                    {
                        <option value="@participant.Id">@participant.Name (@participant.Id)</option>
                    }
                </select>
                <button class="btn btn-sm btn-outline-secondary" @onclick="AssignOwnerToSelectedPiece">Apply Owner</button>
            </div>
        }
    }

    <h3>Pieces</h3>

    @if (WorkspaceService.State.CurrentTableSession.Pieces.Count == 0)
    {
        <p>No pieces in current session.</p>
    }
    else
    {
        <div class="mb-3">
            <label class="form-label">Select piece</label>
            <select class="form-select" @bind="selectedPieceId" @bind:after="OnSelectedPieceChangedFromList">
                <option value="">(select piece)</option>
                @foreach (var piece in WorkspaceService.State.CurrentTableSession.Pieces)
                {
                    <option value="@piece.Id">@piece.Id (@piece.DefinitionId)</option>
                }
            </select>
        </div>

        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Surface</th>
                    <th>X</th>
                    <th>Y</th>
                    <th>Rotation</th>
                    <th>Owner</th>
                    <th>Markers</th>
                    <th>State Keys</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var piece in WorkspaceService.State.CurrentTableSession.Pieces)
                {
                    <tr>
                        <td>@piece.Id</td>
                        <td>@piece.Location.SurfaceId</td>
                        <td>@piece.Location.Coordinate.X</td>
                        <td>@piece.Location.Coordinate.Y</td>
                        <td>@piece.Rotation.Degrees</td>
                        <td>@GetOwnerDisplayForPiece(piece)</td>
                        <td>@piece.MarkerIds.Count</td>
                        <td>@piece.State.Count</td>
                    </tr>
                }
            </tbody>
        </table>

        <h4>Move Piece</h4>
        <div class="row g-2 mb-3">
            <div class="col">
                <InputText @bind-Value="moveSurfaceId" class="form-control" placeholder="Surface Id" />
            </div>
            <div class="col">
                <InputNumber @bind-Value="moveX" class="form-control" />
            </div>
            <div class="col">
                <InputNumber @bind-Value="moveY" class="form-control" />
            </div>
            <div class="col-auto">
                <button class="btn btn-outline-primary" @onclick="MovePiece">Move</button>
            </div>
        </div>

        <h4>Rotate Piece</h4>
        <div class="row g-2 mb-3">
            <div class="col">
                <InputNumber @bind-Value="rotateDegrees" class="form-control" />
            </div>
            <div class="col-auto">
                <button class="btn btn-outline-primary" @onclick="RotatePiece">Rotate</button>
            </div>
        </div>

        <h4>Add Marker</h4>
        <div class="row g-2 mb-3">
            <div class="col">
                <InputText @bind-Value="markerId" class="form-control" placeholder="Marker Id" />
            </div>
            <div class="col-auto">
                <button class="btn btn-outline-primary" @onclick="AddMarker">Add Marker</button>
            </div>
        </div>

        <h4>Remove Marker</h4>
        <div class="row g-2 mb-3">
            <div class="col">
                <InputText @bind-Value="markerId" class="form-control" placeholder="Marker Id" />
            </div>
            <div class="col-auto">
                <button class="btn btn-outline-primary" @onclick="RemoveMarker">Remove Marker</button>
            </div>
        </div>

        <h4>Change Piece State</h4>
        <div class="row g-2 mb-3">
            <div class="col">
                <InputText @bind-Value="stateKey" class="form-control" placeholder="State Key" />
            </div>
            <div class="col">
                <InputText @bind-Value="stateValue" class="form-control" placeholder="State Value" />
            </div>
            <div class="col-auto">
                <button class="btn btn-outline-primary" @onclick="ChangePieceState">Update State</button>
            </div>
        </div>
    }
}

    </div>
</aside>

@if (WorkspaceService.State.OperationHistory.Count > 0)
{
    <h3>Recent Operations</h3>
    <ul>
        @foreach (var item in WorkspaceService.State.OperationHistory.TakeLast(10).Reverse())
        {
            <li>@item.TimestampUtc:u - @item.OperationKind - @(item.Success ? "Success" : "Failed") - @item.Message</li>
        }
    </ul>
}

@if (WorkspaceService.State.CurrentTableSession is not null)
{
    <h3>Play Log</h3>
    @if (WorkspaceService.State.CurrentTableSession.ActionLog.Count == 0)
    {
        <p>No actions recorded yet.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Time (UTC)</th>
                        <th>Action</th>
                        <th>Actor</th>
                        <th>Summary</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var action in WorkspaceService.State.CurrentTableSession.ActionLog.TakeLast(20).Reverse())
                    {
                        <tr>
                            <td>@action.TimestampUtc.ToString("u")</td>
                            <td>@action.ActionType</td>
                            <td>@action.ActorParticipantId</td>
                            <td>@ActionFeedSummaryFormatter.SummarizeActionPayload(action)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}


