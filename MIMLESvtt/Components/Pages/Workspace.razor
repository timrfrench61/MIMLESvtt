    </div>
</aside>

@if (WorkspaceService.State.OperationHistory.Count > 0)
{
    <h3>Recent Operations</h3>
    <ul>
        @foreach (var item in WorkspaceService.State.OperationHistory.TakeLast(10).Reverse())
        {
            <li>@item.TimestampUtc:u - @item.OperationKind - @(item.Success ? "Success" : "Failed") - @item.Message</li>
        }
    </ul>
}

@if (WorkspaceService.State.CurrentVttSession is not null)
{
    <h3>Play Log</h3>
    @if (WorkspaceService.State.CurrentVttSession.ActionLog.Count == 0)
    {
        <p>No actions recorded yet.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Time (UTC)</th>
                        <th>Action</th>
                        <th>Actor</th>
                        <th>Summary</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var action in WorkspaceService.State.CurrentVttSession.ActionLog.TakeLast(20).Reverse())
                    {
                        <tr>
                            <td>@action.TimestampUtc.ToString("u")</td>
                            <td>@action.ActionType</td>
                            <td>@action.ActorParticipantId</td>
                            <td>@ActionFeedSummaryFormatter.SummarizeActionPayload(action)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}


