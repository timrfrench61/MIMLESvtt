@page "/content/magic-items"
@attribute [Authorize]

<PageTitle>Magic Items</PageTitle>

<h1 id="top-magic-items">Magic Items</h1>

<p class="text-muted">Search, review, and maintain magic item entries from this screen.</p>

<div class="mb-3 d-flex gap-2 flex-wrap">
    <a class="btn btn-outline-secondary" href="/content">Back to Content Home</a>
    <a class="btn btn-outline-secondary" href="/content/import">Open Import</a>
</div>

<h6 class="mb-2">Related Content</h6>
<div class="mb-3 d-flex gap-2 flex-wrap">
    <a class="btn btn-outline-secondary" href="/content/monsters">Open Monsters</a>
    <a class="btn btn-outline-secondary" href="/content/treasure">Open Treasure</a>
    <a class="btn btn-outline-secondary" href="/content/equipment">Open Equipment</a>
    <span class="badge text-bg-primary align-self-center">Current: Magic Items</span>
</div>
<small class="text-muted d-block mb-3">Use related links to continue cross-type content review after finishing this page.</small>

<div class="mb-3 d-flex gap-2 flex-wrap">
    <button class="btn btn-sm btn-outline-secondary" @onclick="StartCreateMode">Start New Entry</button>
    <a class="btn btn-sm btn-outline-secondary" href="/content/import">Open Import Workflow</a>
    <a class="btn btn-sm btn-outline-secondary" href="/content">Open Content Hub</a>
</div>

<div class="mb-3 d-flex gap-2 flex-wrap">
    <a class="btn btn-sm btn-outline-secondary" href="#top-magic-items">Top</a>
    <a class="btn btn-sm btn-outline-secondary" href="#find-magic-items">Find</a>
    <a class="btn btn-sm btn-outline-secondary" href="#list-magic-items">List</a>
    <a class="btn btn-sm btn-outline-secondary" href="#details-magic-items">Details</a>
    <a class="btn btn-sm btn-outline-secondary" href="#edit-magic-items">Entry/Edit</a>
</div>
<small class="text-muted d-block mb-3">Recommended sequence: Find -> List -> Details -> Entry/Edit.</small>

<h5 id="find-magic-items">Find Magic Items</h5>
<p class="text-muted mb-2">Use search, rarity, and type filters to narrow the list before opening details or edit mode.</p>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Search</label>
                <InputText class="form-control" @bind-Value="searchQuery" placeholder="Search name, id, rarity, or type" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Rarity</label>
                <InputSelect class="form-select" @bind-Value="rarityFilter">
                    <option value="">All</option>
                    @foreach (var rarity in AvailableRarities)
                    {
                        <option value="@rarity">@rarity</option>
                    }
                </InputSelect>
            </div>
            <div class="col-md-3">
                <label class="form-label">Type</label>
                <InputSelect class="form-select" @bind-Value="typeFilter">
                    <option value="">All</option>
                    @foreach (var type in AvailableTypes)
                    {
                        <option value="@type">@type</option>
                    }
                </InputSelect>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-secondary w-100" @onclick="ClearFilters">Clear</button>
            </div>
        </div>
        <small class="text-muted d-block mt-2">Tip: rarity + type filters provide the fastest path to target item sets.</small>
    </div>
</div>

<h5 id="list-magic-items">Magic Item List Results</h5>
<div class="mb-2 d-flex gap-3 flex-wrap">
    <small class="text-muted">Visible: <strong>@VisibleMagicItems.Count</strong></small>
    <small class="text-muted">Selected: <strong>@(string.IsNullOrWhiteSpace(selectedMagicItemId) ? "(none)" : selectedMagicItemId)</strong></small>
</div>
<div class="card">
    <div class="card-body">
        @if (VisibleMagicItems.Count == 0)
        {
            <div class="alert alert-light border mb-0">No magic items match current filters. Try clearing filters or broadening your search.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Rarity</th>
                            <th class="text-end">Charges</th>
                            <th class="text-end">Attunement</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in VisibleMagicItems)
                        {
                            <tr class="@(string.Equals(item.Id, selectedMagicItemId, StringComparison.Ordinal) ? "table-primary" : string.Empty)">
                                <td><code>@item.Id</code></td>
                                <td>@item.Name</td>
                                <td>@item.ItemType</td>
                                <td>@item.Rarity</td>
                                <td class="text-end">@(item.Charges?.ToString() ?? "-")</td>
                                <td class="text-end">@(item.AttunementRequired ? "Yes" : "No")</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => SelectMagicItem(item.Id)">View</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

<div class="mt-2 d-flex gap-2 flex-wrap">
    <a class="btn btn-sm btn-outline-secondary" href="#edit-magic-items">Go to Entry/Edit</a>
    <a class="btn btn-sm btn-outline-secondary" href="#top-magic-items">Back to Top</a>
</div>
        }
        <small class="text-muted d-block mt-2">Select any row and choose <strong>View</strong> to populate the detail panel below.</small>
    </div>
</div>

<h5 id="details-magic-items" class="mt-4">Magic Item Details</h5>
<p class="text-muted mb-2">Review read-only detail values before applying entry/edit changes.</p>
<div class="mb-2 d-flex gap-3 flex-wrap">
    <small class="text-muted">Selected: <strong>@(string.IsNullOrWhiteSpace(selectedMagicItemId) ? "(none)" : selectedMagicItemId)</strong></small>
    <small class="text-muted">Editor Mode: <strong>@(IsEditMode ? "Edit" : "Create")</strong></small>
</div>

<div class="card mt-3">
    <div class="card-body">
        <h5 class="card-title">Magic Item Detail (Read-only)</h5>
        @if (SelectedMagicItem is null)
        {
            <div class="alert alert-light border mb-0">Select a magic item entry from the list to view details.</div>
        }
        else
        {
            <dl class="row mb-0">
                <dt class="col-sm-3">Id</dt>
                <dd class="col-sm-9"><code>@SelectedMagicItem.Id</code></dd>

                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@SelectedMagicItem.Name</dd>

                <dt class="col-sm-3">Type</dt>
                <dd class="col-sm-9">@SelectedMagicItem.ItemType</dd>

                <dt class="col-sm-3">Rarity</dt>
                <dd class="col-sm-9">@SelectedMagicItem.Rarity</dd>

                <dt class="col-sm-3">Attunement Required</dt>
                <dd class="col-sm-9">@(SelectedMagicItem.AttunementRequired ? "Yes" : "No")</dd>

                <dt class="col-sm-3">Charges</dt>
                <dd class="col-sm-9">@(SelectedMagicItem.Charges?.ToString() ?? "(none)")</dd>

                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">@SelectedMagicItem.Description</dd>

                <dt class="col-sm-3">Source</dt>
                <dd class="col-sm-9">@SelectedMagicItem.Source</dd>

                <dt class="col-sm-3">Tags</dt>
                <dd class="col-sm-9">@SelectedMagicItem.Tags</dd>

                <dt class="col-sm-3">Effect Metadata</dt>
                <dd class="col-sm-9">
                    @if (SelectedMagicItem.EffectMetadataRows.Count == 0)
                    {
                        <span class="text-muted">(none)</span>
                    }
                    else
                    {
                        <ul class="mb-0">
                            @foreach (var effect in SelectedMagicItem.EffectMetadataRows)
                            {
                                <li><strong>@effect.Section</strong> - <code>@effect.Key</code>: @effect.Value</li>
                            }
                        </ul>
                    }
                </dd>
            </dl>
        }
    </div>
</div>

<h5 id="edit-magic-items" class="mt-4">Magic Item Entry/Edit</h5>
<p class="text-muted mb-2">Use this section to create a new magic item or edit the currently selected entry.</p>

<div class="card mt-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h5 class="card-title mb-0">Magic Item Entry/Edit</h5>
            <span class="badge @(IsEditMode ? "text-bg-primary" : "text-bg-secondary")">@(IsEditMode ? "Edit" : "Create")</span>
        </div>

        <div class="row g-2">
            <div class="col-md-4">
                <label class="form-label">Id (required)</label>
                <InputText class="form-control" @bind-Value="editId" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Name (required)</label>
                <InputText class="form-control" @bind-Value="editName" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Type (required)</label>
                <InputText class="form-control" @bind-Value="editItemType" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Rarity</label>
                <InputText class="form-control" @bind-Value="editRarity" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Charges (optional, >= 0)</label>
                <InputNumber class="form-control" @bind-Value="editCharges" />
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <div class="form-check mb-2">
                    <InputCheckbox id="magic-item-attunement" class="form-check-input" @bind-Value="editAttunementRequired" />
                    <label class="form-check-label" for="magic-item-attunement">Attunement Required</label>
                </div>
            </div>
            <div class="col-md-4">
                <label class="form-label">Source</label>
                <InputText class="form-control" @bind-Value="editSource" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Tags</label>
                <InputText class="form-control" @bind-Value="editTags" />
            </div>
            <div class="col-12">
                <label class="form-label">Description</label>
                <InputTextArea class="form-control" @bind-Value="editDescription" rows="2" />
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="mb-0">Structured Effect Metadata</h6>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="AddEffectMetadataRow">Add Effect Row</button>
                </div>
                <small class="text-muted d-block mb-2">Use metadata rows to capture passive, activated, trigger, and duration effect details.</small>

                @if (effectMetadataRows.Count == 0)
                {
                    <div class="alert alert-light border mb-0">No effect metadata rows. Add passive/activated/trigger/duration hints as needed.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Section</th>
                                    <th>Key (required when row has values)</th>
                                    <th>Value</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (var i = 0; i < effectMetadataRows.Count; i++)
                                {
                                    var row = effectMetadataRows[i];
                                    <tr>
                                        <td><InputText class="form-control" @bind-Value="row.Section" placeholder="Passive / Activated / Trigger / Duration" /></td>
                                        <td><InputText class="form-control" @bind-Value="row.Key" /></td>
                                        <td><InputText class="form-control" @bind-Value="row.Value" /></td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveEffectMetadataRow(i)">Remove</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="d-flex gap-2 mt-3">
            <button class="btn btn-outline-secondary" @onclick="ValidateEditorForm">Validate Form</button>
            <button class="btn btn-primary" @onclick="SaveMagicItem">Save</button>
            <button class="btn btn-outline-warning" @onclick="CancelEdit">Cancel</button>
            <button class="btn btn-outline-secondary" @onclick="StartCreateMode">New (Create Mode)</button>
        </div>

        <small class="text-muted d-block mt-2">Validate is optional pre-check. Save is the primary action for persisting changes.</small>
        <small class="text-muted d-block">Use <strong>New</strong> to clear editor values and start a fresh entry after save/review.</small>
        <small class="text-muted d-block">Use <strong>Cancel</strong> to leave edit mode without persisting form changes.</small>

        @if (!string.IsNullOrWhiteSpace(editorValidationMessage))
        {
            <div class="alert @(editorValidationPassed ? "alert-success" : "alert-danger") mt-3 mb-0">@editorValidationMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(editorSaveMessage))
        {
            <div class="alert @(editorSaveSucceeded ? "alert-success" : "alert-danger") mt-2 mb-0">@editorSaveMessage</div>
        }
    </div>
</div>
