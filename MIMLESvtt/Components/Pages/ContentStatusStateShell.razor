@using Microsoft.AspNetCore.Components

<div class="card mb-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h5 class="card-title mb-0">@Title</h5>
            <span class="badge text-bg-secondary">Reusable State Shell</span>
        </div>

        <p class="text-muted mb-3">Preview standardized content-list states for empty, loading, success, and error scenarios.</p>

        <div class="mb-3 d-flex gap-2 flex-wrap">
            <a class="btn btn-sm btn-outline-secondary" href="#status-state-controls">Controls</a>
            <a class="btn btn-sm btn-outline-secondary" href="#status-state-preview">Preview</a>
        </div>

        <div class="mb-2">
            <small class="text-muted">Current State: <strong>@CurrentState</strong></small>
        </div>

        <div class="mb-2">
            <small class="text-muted">Use this shell to verify copy tone and actionability before applying to production lists.</small>
        </div>

        <div id="status-state-controls" class="d-flex flex-wrap gap-2 mb-3">
            <button class="btn btn-sm @(CurrentState == ContentStatusState.Empty ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetState(ContentStatusState.Empty)">Empty</button>
            <button class="btn btn-sm @(CurrentState == ContentStatusState.Loading ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetState(ContentStatusState.Loading)">Loading</button>
            <button class="btn btn-sm @(CurrentState == ContentStatusState.Error ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetState(ContentStatusState.Error)">Error</button>
            <button class="btn btn-sm @(CurrentState == ContentStatusState.Success ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetState(ContentStatusState.Success)">Success</button>
        </div>
        <small class="text-muted d-block mb-3">Choose a state to preview reusable status messaging behavior.</small>
        <small class="text-muted d-block mb-3">Recommended validation order: Empty -> Loading -> Success -> Error.</small>

        <div class="mb-3 d-flex gap-2 flex-wrap">
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => SetState(ContentStatusState.Empty)">Reset to Empty</button>
        </div>

        <div id="status-state-preview">
        @if (CurrentState == ContentStatusState.Empty)
        {
            <div class="alert alert-light border mb-0">
                <strong>Empty State</strong><br />
                Placeholder for no-items/no-results messaging.
            </div>
            <small class="text-muted d-block mt-2">Use when a list has no entries or a filter returns no matches.</small>
        }
        else if (CurrentState == ContentStatusState.Loading)
        {
            <div class="alert alert-light border mb-0">
                <strong>Loading State</strong><br />
                Placeholder for load-progress/status indicator.
            </div>
            <small class="text-muted d-block mt-2">Use while loading list data or running background refresh operations.</small>
        }
        else if (CurrentState == ContentStatusState.Success)
        {
            <div class="alert alert-success mb-0">
                <strong>Success State</strong><br />
                Placeholder for completed save/import/update confirmation.
            </div>
            <small class="text-muted d-block mt-2">Use after successful create/update/import actions with clear next-step guidance.</small>
        }
        else
        {
            <div class="alert alert-danger mb-0">
                <strong>Error State</strong><br />
                Placeholder for user-visible load/process error details.
            </div>
            <small class="text-muted d-block mt-2">Use for blocking failures and include retry or recovery instructions.</small>
        }
        </div>

        <div class="mt-3 text-end">
            <small class="text-muted">Reusable shell preview for content state messaging behavior.</small>
        </div>

        <div class="mt-2 d-flex gap-2 flex-wrap">
            <a class="btn btn-sm btn-outline-secondary" href="/content/import">Open Import</a>
            <a class="btn btn-sm btn-outline-secondary" href="/content">Open Content Hub</a>
            <a class="btn btn-sm btn-outline-secondary" href="#status-state-controls">Back to Controls</a>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Content State";

    private ContentStatusState CurrentState { get; set; } = ContentStatusState.Empty;

    private void SetState(ContentStatusState state)
    {
        CurrentState = state;
    }

    private enum ContentStatusState
    {
        Empty,
        Loading,
        Error,
        Success
    }
}
