@using MIMLESvtt.Services

<div class="card mb-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h5 class="card-title mb-0">Import Workflow</h5>
            <span class="badge text-bg-secondary">Reusable Shell</span>
        </div>

        <p class="text-muted mb-3">Upload, validate, and persist content imports using a staged workflow.</p>

        <div class="alert alert-light border py-2">
            <strong>Current Selection</strong><br />
            File: <code>@(string.IsNullOrWhiteSpace(selectedFilePath) ? "content-import.csv" : selectedFilePath)</code> |
            Type: <strong>@importType</strong> |
            Duplicate Policy: <strong>@duplicatePolicy</strong>
        </div>

        <div class="mb-2 d-flex gap-3 flex-wrap align-items-center">
            <small class="text-muted">Last Run (UTC): <strong>@LastRunDisplay</strong></small>
            <small class="text-muted">Validation Runs: <strong>@validationRunCount</strong></small>
            <small class="text-muted">Errors: <strong>@ErrorCount</strong></small>
            <small class="text-muted">Warnings: <strong>@WarningCount</strong></small>
            <small class="text-muted">History Events: <strong>@StageHistoryCount</strong></small>
        </div>

        <div class="mb-3">
            <small class="text-muted">Current Stage: <strong>@CurrentStage</strong></small>
            <br />
            <small class="text-muted">@CurrentStageGuidance</small>
        </div>

        <div class="mb-2">
            <small class="text-muted">Use stage buttons to preview branch behavior without leaving this page.</small>
        </div>

        <div class="d-flex flex-wrap gap-2 mb-2">
            <button class="btn btn-sm @(CurrentStage == ContentImportStage.Upload ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetStage(ContentImportStage.Upload)">Upload</button>
            <button class="btn btn-sm @(CurrentStage == ContentImportStage.Validate ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetStage(ContentImportStage.Validate)">Validate</button>
            <button class="btn btn-sm @(CurrentStage == ContentImportStage.Persist ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetStage(ContentImportStage.Persist)">Persist Review</button>
            <button class="btn btn-sm @(CurrentStage == ContentImportStage.Summarize ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetStage(ContentImportStage.Summarize)">Summary</button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="RetryFromErrors">Reset to Upload</button>
        </div>
        <small class="text-muted d-block mb-2">Jump directly to any stage for shell preview and documentation walkthroughs.</small>
        <small class="text-muted d-block mb-3">Progression: Upload → Validate → Persist Review → Summary</small>

        <div class="mb-3 d-flex gap-2 flex-wrap">
            <a class="btn btn-sm btn-outline-secondary" href="#import-stage-history">History</a>
            <a class="btn btn-sm btn-outline-secondary" href="#import-stage-main">Current Stage</a>
        </div>

        <div id="import-stage-main">
        @if (CurrentStage == ContentImportStage.Upload)
        {
            <div class="row g-2">
                <div class="col-md-6">
                    <label class="form-label">Import file path</label>
                    <InputText class="form-control" @bind-Value="selectedFilePath" placeholder="C:\\imports\\content.csv" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Import type</label>
                    <InputSelect class="form-select" @bind-Value="importType">
                        <option value="Monster">Monster</option>
                        <option value="Treasure">Treasure</option>
                        <option value="Equipment">Equipment</option>
                        <option value="MagicItem">Magic Item</option>
                        <option value="UnitCounter">Unit/Counter</option>
                    </InputSelect>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Duplicate policy</label>
                    <InputSelect class="form-select" @bind-Value="duplicatePolicy">
                        <option value="@ContentImportDuplicatePolicy.RejectDuplicate">Reject Duplicate</option>
                        <option value="@ContentImportDuplicatePolicy.SkipDuplicate">Skip Duplicate</option>
                        <option value="@ContentImportDuplicatePolicy.UpdateDuplicate">Update Duplicate</option>
                    </InputSelect>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-primary w-100" @onclick="ValidateImportPreview">Validate Preview</button>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-outline-secondary w-100" @onclick="RetryFromErrors">Reset</button>
                </div>
            </div>
            <small class="text-muted d-block mt-2">Tip: keep the default sample file path for shell preview or provide a custom path for context.</small>
            <div class="alert alert-light border mt-3 mb-0">
                <strong>Upload Stage</strong><br />
                Select file/type and run parse/map/validate preview.
            </div>
            <small class="text-muted d-block mt-2">Validate Preview runs parser/mapping checks using selected type and policy.</small>
            <small class="text-muted d-block">Reset returns to Upload and clears stage progression context for a fresh pass.</small>
        }
        else if (CurrentStage == ContentImportStage.Validate)
        {
            <div class="alert alert-light border mb-2">
                <strong>Validation Preview</strong><br />
                Rows: @resultState.TotalRows | Created: @resultState.CreatedCount | Updated: @resultState.UpdatedCount | Failed: @resultState.FailedCount
            </div>
            @if (resultState.Issues.Any(i => i.Severity == ContentImportIssueSeverity.Error))
            {
                <div class="alert alert-warning mb-2">Validation found blocking errors. Continue to Persist Review for issue details.</div>
            }
            else
            {
                <div class="alert alert-success mb-2">Validation has no blocking errors. Continue to summary when ready.</div>
            }
            @if (resultState.Messages.Count == 0)
            {
                <div class="alert alert-info mb-3">No validation messages were produced for this preview.</div>
            }
            else
            {
                <ul class="mb-3">
                    @foreach (var message in resultState.Messages)
                    {
                        <li>@message</li>
                    }
                </ul>
            }
            <button class="btn btn-primary" @onclick="ContinueFromValidation">Continue</button>
            <button class="btn btn-outline-secondary ms-2" @onclick="RetryFromErrors">Back to Upload</button>
            @if (HasBlockingErrors)
            {
                <small class="text-danger d-block mt-2">Blocking errors detected. Continue routes to Persist Review.</small>
            }
            <small class="text-muted d-block mt-2">Continue advances stage based on validation results.</small>
            <small class="text-muted d-block">No blocking errors -> Summary; blocking errors -> Persist Review.</small>
            <small class="text-muted d-block">Back to Upload lets you adjust import type or duplicate policy before rerunning validation.</small>
        }
        else if (CurrentStage == ContentImportStage.Persist)
        {
            var errorCount = resultState.Issues.Count(i => i.Severity == ContentImportIssueSeverity.Error);
            var warningCount = resultState.Issues.Count(i => i.Severity == ContentImportIssueSeverity.Warning);
            var persistAlertClass = errorCount > 0 ? "alert-danger" : "alert-warning";
            <div class="alert @persistAlertClass mb-2">
                <strong>Persist / Issue Review</strong><br />
                Errors: @errorCount |
                Warnings: @warningCount
            </div>
            @if (resultState.Issues.Count == 0)
            {
                <div class="alert alert-success mb-3">No issues found. This import is ready for summary.</div>
            }
            else
            {
                <ul class="mb-3">
                    @foreach (var issue in resultState.Issues)
                    {
                        <li>[@issue.Severity] (@issue.Stage) Row @(issue.RowIndex?.ToString() ?? "-") @issue.Message</li>
                    }
                </ul>
            }
            <button class="btn btn-primary" @onclick="RetryFromErrors">Back to Upload</button>
            @if (!HasAnyIssues)
            {
                <small class="text-success d-block mt-2">No issues currently tracked for Persist Review.</small>
            }
            <small class="text-muted d-block mt-2">Resolve issues by adjusting input selections and re-running validation from Upload.</small>
            <small class="text-muted d-block">Persist Review is issue triage only in this shell preview path.</small>
            <small class="text-muted d-block">Use issue rows to identify stage and row index before retrying.</small>
        }
        else
        {
            <div class="alert alert-success mb-0">
                <strong>Success Summary</strong><br />
                Created: @resultState.CreatedCount | Updated: @resultState.UpdatedCount | Skipped: @resultState.SkippedCount | Failed: @resultState.FailedCount
            </div>
            <small class="text-muted d-block mt-2">Review totals above, then run another import or return to content pages.</small>
            <div class="mt-2">
                <button class="btn btn-outline-secondary" @onclick="RetryFromErrors">Run Another Import</button>
            </div>
            <small class="text-muted d-block mt-2">Run Another Import resets the workflow back to Upload.</small>
            <small class="text-muted d-block">Summary is the final confirmation step for this shell preview cycle.</small>
        }
        </div>

        @if (StageHistory.Count > 0)
        {
            <div id="import-stage-history" class="mt-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="mb-0">Stage History</h6>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ClearStageHistory">Clear History</button>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>UTC Time</th>
                                <th>Stage</th>
                                <th>Message</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var history in StageHistory)
                            {
                                <tr>
                                    <td><small>@history.TimestampUtc.ToString("u")</small></td>
                                    <td><span class="badge @GetStageBadgeClass(history.Stage)">@history.Stage</span></td>
                                    <td><small>@history.Message</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <div class="mt-3 text-end">
            <small class="text-muted">Reusable shell preview for import workflow behavior.</small>
        </div>
    </div>
</div>
