@using MIMLESvtt.src.Domain.Models.Content.Import

<div class="card mb-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h5 class="card-title mb-0">Import Workflow</h5>
            <span class="badge text-bg-secondary">Reusable Shell</span>
        </div>

        <div class="d-flex flex-wrap gap-2 mb-3">
            <button class="btn btn-sm @(CurrentStage == CsvImportStage.Upload ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetStage(CsvImportStage.Upload)">Upload</button>
            <button class="btn btn-sm @(CurrentStage == CsvImportStage.Validate ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetStage(CsvImportStage.Validate)">Validate</button>
            <button class="btn btn-sm @(CurrentStage == CsvImportStage.Persist ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetStage(CsvImportStage.Persist)">Persist Review</button>
            <button class="btn btn-sm @(CurrentStage == CsvImportStage.Summarize ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetStage(CsvImportStage.Summarize)">Summary</button>
        </div>

        @if (CurrentStage == CsvImportStage.Upload)
        {
            <div class="row g-2">
                <div class="col-md-6">
                    <label class="form-label">Import file path</label>
                    <InputText class="form-control" @bind-Value="selectedFilePath" placeholder="C:\\imports\\content.csv" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Import type</label>
                    <InputSelect class="form-select" @bind-Value="importType">
                        <option value="Monster">Monster</option>
                        <option value="Treasure">Treasure</option>
                        <option value="Equipment">Equipment</option>
                        <option value="MagicItem">Magic Item</option>
                        <option value="UnitCounter">Unit/Counter</option>
                    </InputSelect>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Duplicate policy</label>
                    <InputSelect class="form-select" @bind-Value="duplicatePolicy">
                        <option value="@CsvDuplicateHandlingPolicy.RejectDuplicate">Reject Duplicate</option>
                        <option value="@CsvDuplicateHandlingPolicy.SkipDuplicate">Skip Duplicate</option>
                        <option value="@CsvDuplicateHandlingPolicy.UpdateDuplicate">Update Duplicate</option>
                    </InputSelect>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-primary w-100" @onclick="ValidateImportPreview">Validate Preview</button>
                </div>
            </div>
            <div class="alert alert-light border mt-3 mb-0">
                <strong>Upload Stage</strong><br />
                Select file/type and run parse/map/validate preview.
            </div>
        }
        else if (CurrentStage == CsvImportStage.Validate)
        {
            <div class="alert alert-light border mb-2">
                <strong>Validation Preview</strong><br />
                Rows: @resultState.TotalRows | Created: @resultState.CreatedCount | Updated: @resultState.UpdatedCount | Failed: @resultState.FailedCount
            </div>
            <ul class="mb-3">
                @foreach (var message in resultState.Messages)
                {
                    <li>@message</li>
                }
            </ul>
            <button class="btn btn-primary" @onclick="ContinueFromValidation">Continue</button>
        }
        else if (CurrentStage == CsvImportStage.Persist)
        {
            <div class="alert alert-danger mb-2">
                <strong>Persist / Issue Review</strong><br />
                Errors: @resultState.Issues.Count(i => i.Severity == CsvImportIssueSeverity.Error) |
                Warnings: @resultState.Issues.Count(i => i.Severity == CsvImportIssueSeverity.Warning)
            </div>
            <ul class="mb-3">
                @foreach (var issue in resultState.Issues)
                {
                    <li>[@issue.Severity] (@issue.Stage) Row @(issue.RowIndex?.ToString() ?? "-") @issue.Message</li>
                }
            </ul>
            <button class="btn btn-outline-primary" @onclick="RetryFromErrors">Retry</button>
        }
        else
        {
            <div class="alert alert-success mb-0">
                <strong>Success Summary</strong><br />
                Created: @resultState.CreatedCount | Updated: @resultState.UpdatedCount | Skipped: @resultState.SkippedCount | Failed: @resultState.FailedCount
            </div>
        }
    </div>
</div>
