@page "/logout"

<PageTitle>Logout</PageTitle>

<h1>Sign out</h1>

<AuthorizeView>
    <Authorized>
        <form method="post" action="/auth/logout" style="max-width: 360px;">
            <input type="hidden" name="returnUrl" value="/" />
            <button class="btn btn-outline-danger" type="submit">Sign out</button>
        </form>
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-info">You are already signed out.</div>
        <a class="btn btn-outline-primary" href="/login">Sign in</a>
    </NotAuthorized>
</AuthorizeView>
