<div class="card">
    <div class="card-body">
        <h5 class="card-title">Toolbar</h5>

        <div class="d-flex gap-2 flex-wrap mb-2">
            <button class="btn btn-outline-secondary" @onclick='() => OnSetTool.InvokeAsync("Select")'>Select</button>
            <button class="btn btn-outline-secondary" @onclick='() => OnSetTool.InvokeAsync("Move")'>Move</button>
            <button class="btn btn-outline-secondary" @onclick='() => OnSetTool.InvokeAsync("Rotate")'>Rotate</button>
        </div>

        <div class="d-flex gap-2 flex-wrap mb-2">
            <button class="btn btn-outline-secondary" @onclick="() => OnMove.InvokeAsync((0, -1))">Up</button>
            <button class="btn btn-outline-secondary" @onclick="() => OnMove.InvokeAsync((-1, 0))">Left</button>
            <button class="btn btn-outline-secondary" @onclick="() => OnMove.InvokeAsync((1, 0))">Right</button>
            <button class="btn btn-outline-secondary" @onclick="() => OnMove.InvokeAsync((0, 1))">Down</button>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-outline-secondary" @onclick="() => OnRotate.InvokeAsync(90)">Rotate +90°</button>
            <button class="btn btn-outline-secondary" @onclick="() => OnRotate.InvokeAsync(-90)">Rotate -90°</button>
            <button class="btn btn-primary" @onclick="OnEndTurn">End Turn</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback<string> OnSetTool { get; set; }
    [Parameter] public EventCallback<(int DeltaX, int DeltaY)> OnMove { get; set; }
    [Parameter] public EventCallback<int> OnRotate { get; set; }
    [Parameter] public EventCallback OnEndTurn { get; set; }
}
